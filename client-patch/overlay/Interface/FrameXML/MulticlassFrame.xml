<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
	<Script file="MulticlassFrame.lua"/>
	<Frame name="MulticlassFrame" toplevel="true" enableMouse="true" hidden="true" parent="UIParent">
		<Size>
			<AbsDimension x="416" y="280"/>
		</Size>
		<Anchors>
			<Anchor point="TOPLEFT">
				<Offset>
					<AbsDimension x="0" y="-104"/>
				</Offset>
			</Anchor>
		</Anchors>
		<Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
			<BackgroundInsets>
				<AbsInset left="11" right="12" top="12" bottom="11"/>
			</BackgroundInsets>
			<TileSize>
				<AbsValue val="32"/>
			</TileSize>
			<EdgeSize>
				<AbsValue val="32"/>
			</EdgeSize>
		</Backdrop>
		<Layers>
			<Layer level="ARTWORK">
				<Texture name="MulticlassFramePortrait">
					<Size>
						<AbsDimension x="50" y="50"/>
					</Size>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset>
								<AbsDimension x="14" y="-12"/>
							</Offset>
						</Anchor>
					</Anchors>
				</Texture>
				<FontString name="MulticlassFrameTitle" inherits="GameFontNormal" text="Classes">
					<Anchors>
						<Anchor point="TOP">
							<Offset>
								<AbsDimension x="0" y="-14"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
				<FontString name="MulticlassFrameIdentity" inherits="GameFontNormalLarge">
					<Anchors>
						<Anchor point="TOP">
							<Offset>
								<AbsDimension x="0" y="-34"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
				<FontString name="MulticlassFrameHint" inherits="GameFontDisableSmall" justifyH="CENTER">
					<Anchors>
						<Anchor point="BOTTOM">
							<Offset>
								<AbsDimension x="0" y="12"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="MulticlassFrameCloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT">
						<Offset>
							<AbsDimension x="-6" y="-6"/>
						</Offset>
					</Anchor>
				</Anchors>
			</Button>
		</Frames>
		<Scripts>
			<OnLoad>
				SetPortraitTexture(MulticlassFramePortrait, "player");
				MulticlassUI:OnFrameLoad(self);
			</OnLoad>
			<OnShow>
				MulticlassUI:OnShow();
			</OnShow>
			<OnHide>
				UpdateMicroButtons();
			</OnHide>
			<OnEvent>
				MulticlassUI:OnFrameEvent(event, ...);
			</OnEvent>
		</Scripts>
	</Frame>
</Ui>
